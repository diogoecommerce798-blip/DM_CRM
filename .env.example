# DM CRM - Variáveis de Ambiente Necessárias

# -----------------------------------------------------------------------------
# FRONTEND (Vite / Client-side)
# Devem ter o prefixo VITE_ para serem expostas ao browser
# -----------------------------------------------------------------------------

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key

# OAuth / Auth
VITE_APP_ID=your-app-id
VITE_OAUTH_PORTAL_URL=https://auth.your-service.com

# Analytics (Opcional - Evita warnings no build)
VITE_ANALYTICS_ENDPOINT=https://analytics.your-service.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# -----------------------------------------------------------------------------
# BACKEND (Server-side / Vercel Functions)
# Usadas pelo Express / tRPC no runtime
# -----------------------------------------------------------------------------

# Database (Drizzle / MySQL / Postgres)
DATABASE_URL=postgresql://postgres:pass@host:5432/postgres
POSTGRES_URL=postgresql://postgres:pass@host:5432/postgres

# Auth Secrets
JWT_SECRET=your-secure-jwt-secret
OWNER_OPEN_ID=your-admin-openid

# OAuth (Server-side fallback)
OAUTH_SERVER_URL=https://auth.your-service.com
APP_ID=your-app-id

# -----------------------------------------------------------------------------
# INFRA / DEPLOY
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
